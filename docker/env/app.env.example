TZ=Asia/Tokyo

# DB 接続先（php コンテナから db サービスへ接続）
POSLA_DB_HOST=db
POSLA_DB_NAME=odah_eat-posla
POSLA_DB_USER=odah_eat-posla
POSLA_DB_PASS=odah_eat-posla

# Docker ローカル専用。production では未設定のままにする
POSLA_LOCAL_DB_HOST=db
POSLA_LOCAL_DB_NAME=odah_eat-posla
POSLA_LOCAL_DB_USER=odah_eat-posla
POSLA_LOCAL_DB_PASS=odah_eat-posla
POSLA_ENV=local

# 正規 URL / メール / CORS
POSLA_APP_BASE_URL=http://127.0.0.1:8081
POSLA_FROM_EMAIL=noreply@meal.posla.jp
POSLA_SUPPORT_EMAIL=info@meal.posla.jp
POSLA_ALLOWED_ORIGINS=http://127.0.0.1:8081
POSLA_ALLOWED_HOSTS=127.0.0.1,localhost

# Cell / deploy metadata
POSLA_CELL_ID=posla-control-local
POSLA_OPS_SOURCE_ID=posla-control-local
POSLA_ENVIRONMENT=pseudo-prod
POSLA_DEPLOY_VERSION=dev
POSLA_CRON_ENABLED=1

# ログ / cron
POSLA_PHP_ERROR_LOG=/tmp/posla_php_errors.log
POSLA_CRON_SECRET=local-monitor-secret-20260424
POSLA_OPS_READ_SECRET=__REPLACE_SHARED_OPS_READ_SECRET__

# codex-ops-platform Support Case bridge (optional env override)
# 未設定の場合は POSLA管理画面の codex_ops_case_endpoint / codex_ops_case_token を使う。
POSLA_OP_CASE_ENDPOINT=
POSLA_OP_CASE_TOKEN=
POSLA_OP_ALERT_ENDPOINT=
POSLA_OP_ALERT_TOKEN=

# LP申込完了後の専用cell作成trigger
# Web PHP は deploy を直接実行せず、同一ホスト内の trigger service だけを呼ぶ。
POSLA_PROVISIONER_TRIGGER_URL=http://host.docker.internal:19091/run
POSLA_PROVISIONER_TRIGGER_SECRET=__REPLACE_PROVISIONER_TRIGGER_SECRET__
POSLA_PROVISIONER_TRIGGER_TIMEOUT_SEC=2
