# POSLA provisioner runner env
# Copy to docker/env/provisioner.env on the dedicated provisioner VM.
# Do not commit real secrets.

TZ=Asia/Tokyo

# The absolute path must exist on the VM host. The container mounts it at the
# same absolute path so host Docker bind mounts resolve correctly.
POSLA_PROVISIONER_ROOT_DIR=/srv/posla
POSLA_PROVISIONER_PLATFORM=linux/amd64

# Trigger server
POSLA_PROVISIONER_BIND_ADDR=127.0.0.1
POSLA_PROVISIONER_TRIGGER_PORT=19091
POSLA_PROVISIONER_TRIGGER_SECRET=__REPLACE_PROVISIONER_TRIGGER_SECRET__
POSLA_PROVISIONER_TRIGGER_LOG=/srv/posla/cells/provisioner-trigger.log
POSLA_PROVISIONER_LOCK_FILE=/srv/posla/cells/.provisioner.lock
POSLA_CELL_PROVISIONER_ENV_FILE=/srv/posla/docker/env/provisioner.env
POSLA_PROVISIONER_TRIGGER_DRY_RUN=0

# Control DB. Use the POSLA control Cloud SQL private IP / host.
POSLA_CELL_PROVISIONER_DB_HOST=<production-db-host>
POSLA_CELL_PROVISIONER_DB_PORT=3306
POSLA_CELL_PROVISIONER_DB_NAME=<production-db-name>
POSLA_CELL_PROVISIONER_DB_USER=<production-db-user>
POSLA_CELL_PROVISIONER_DB_PASS=<production-db-password>

# Cell creation
POSLA_CELL_PROVISIONER_ENVIRONMENT=production
POSLA_ENVIRONMENT=production
POSLA_DEPLOY_VERSION=<image-or-git-sha>
POSLA_PHP_IMAGE=posla_php_cell:<image-or-git-sha>
POSLA_CELL_APP_URL_PATTERN=https://{tenant_slug}.<production-domain>
POSLA_CELL_HTTP_PORT_BASE=18081
POSLA_CELL_DB_PORT_BASE=13306
POSLA_CELL_DB_USER=posla_app
POSLA_OPS_DB_READONLY_USER=posla_ops_ro
POSLA_OPS_DB_READONLY_HOST=%

# Mail for ready notification
POSLA_FROM_EMAIL=noreply@<production-domain>
POSLA_SUPPORT_EMAIL=support@<production-domain>
POSLA_MAIL_TRANSPORT=sendgrid
POSLA_SENDGRID_API_KEY=__REPLACE_SENDGRID_API_KEY__
POSLA_MAIL_FROM_NAME=POSLA
