TZ=Asia/Tokyo

# Production DB connection
# Cloud Run + Cloud SQL:
# - private IP: set POSLA_DB_HOST=<cloud-sql-private-ip-or-host> and leave POSLA_DB_SOCKET empty
# - Unix socket: set POSLA_DB_SOCKET=/cloudsql/<project>:<region>:<instance> and leave POSLA_DB_HOST empty
POSLA_DB_HOST=<production-db-host>
POSLA_DB_SOCKET=
POSLA_DB_NAME=<production-db-name>
POSLA_DB_USER=<production-db-user>
POSLA_DB_PASS=<production-db-password>

# Production environment marker
POSLA_ENV=production
POSLA_ENVIRONMENT=production

# Public URL / mail / CORS
# These values are required in production. Localhost / http are rejected.
POSLA_APP_BASE_URL=https://<production-domain>
POSLA_FROM_EMAIL=noreply@<production-domain>
POSLA_SUPPORT_EMAIL=support@<production-domain>
POSLA_ALLOWED_ORIGINS=https://<production-domain>
POSLA_ALLOWED_HOSTS=<production-domain>

# Control stack metadata
POSLA_CELL_ID=posla-control
POSLA_OPS_SOURCE_ID=posla-control
POSLA_DEPLOY_VERSION=<image-or-git-sha>
# Cloud Run web services must not run in-container schedulers.
# Use Cloud Scheduler / Cloud Run Jobs for cron workloads.
POSLA_CRON_ENABLED=0

# Logs / internal secrets
POSLA_PHP_ERROR_LOG=/proc/self/fd/2
POSLA_CRON_SECRET=__REPLACE_CRON_SECRET__
POSLA_OPS_READ_SECRET=__REPLACE_SHARED_OPS_READ_SECRET__
POSLA_OP_LAUNCH_SECRET=__REPLACE_SHARED_OP_LAUNCH_SECRET__
# Optional. If unset, monitor-actions uses http://127.0.0.1:${PORT}.
POSLA_INTERNAL_BASE_URL=

# Mail transport
# Cloud Run should use an API transport. PHP mail is only for legacy/local hosting.
POSLA_MAIL_TRANSPORT=sendgrid
POSLA_SENDGRID_API_KEY=__REPLACE_SENDGRID_API_KEY__
POSLA_MAIL_FROM_NAME=POSLA
POSLA_MAIL_TIMEOUT_SEC=8

# PHP session storage
# Redis is required so sessions survive app container rebuilds/deploys.
POSLA_SESSION_STORE=redis
POSLA_SESSION_REDIS_REQUIRED=1
POSLA_SESSION_GC_MAXLIFETIME_SEC=28800
POSLA_REDIS_HOST=<memorystore-redis-host>
POSLA_REDIS_PORT=6379
POSLA_REDIS_DATABASE=0
POSLA_REDIS_SESSION_PREFIX=posla:posla-control:sess:
POSLA_REDIS_TIMEOUT_SEC=1.5
POSLA_REDIS_READ_TIMEOUT_SEC=1.5
POSLA_REDIS_AUTH=

# Rate limit storage
# Cloud Run has ephemeral per-instance /tmp, so use Memorystore for shared limits.
POSLA_RATE_LIMIT_STORE=redis
POSLA_RATE_LIMIT_REDIS_REQUIRED=0
POSLA_REDIS_RATE_LIMIT_PREFIX=posla:posla-control:rate:
# Keep remote_addr unless Cloud Run is the only ingress path and proxy headers are trusted.
POSLA_RATE_LIMIT_CLIENT_IP_SOURCE=remote_addr

# Uploaded file storage
# Mount a Cloud Storage bucket or another shared writable volume to this path.
POSLA_UPLOADS_DIR=/var/www/html/uploads
POSLA_UPLOADS_PUBLIC_PREFIX=uploads

# codex-ops-platform Support Case bridge (optional env override)
# If unset, POSLA Admin API settings are used.
POSLA_OP_CASE_ENDPOINT=https://<op-domain>/api/ingest/posla-case
POSLA_OP_CASE_TOKEN=__REPLACE_POSLA_OPS_CASE_TOKEN__
POSLA_OP_ALERT_ENDPOINT=https://<op-domain>/api/alerts.php
POSLA_OP_ALERT_TOKEN=__REPLACE_OP_ALERT_INGEST_TOKEN__

# Signup -> cell provisioning trigger
# Cloud Run web cannot call a localhost provisioner. Use an external/private provisioner endpoint.
POSLA_PROVISIONER_TRIGGER_URL=https://<provisioner-service-url>/run
POSLA_PROVISIONER_ALLOW_REMOTE_TRIGGER=1
POSLA_PROVISIONER_TRIGGER_SECRET=__REPLACE_PROVISIONER_TRIGGER_SECRET__
POSLA_PROVISIONER_TRIGGER_TIMEOUT_SEC=2

# Customer cell public URL pattern.
# Required by scripts/cell/provision-ready-cells.php outside local/pseudo-prod.
POSLA_CELL_APP_URL_PATTERN=https://{tenant_slug}.<production-domain>

# Cloud Run Job only. Do not set on the web service unless intentionally testing.
# Values: every-5-minutes, hourly, all, monitor-health, reservation-reminders,
# reservation-cleanup, auto-clock-out
POSLA_CRON_TASK=every-5-minutes
