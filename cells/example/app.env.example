TZ=Asia/Tokyo

# DB connection for this cell app container.
POSLA_DB_HOST=db
POSLA_DB_NAME=posla_cell_example
POSLA_DB_USER=posla_app
POSLA_DB_PASS=__REPLACE_DB_PASSWORD__

# Do not set POSLA_ENV=local in production cells.
POSLA_ENV=production

# Canonical URL / email / CORS for this cell.
POSLA_APP_BASE_URL=https://<production-domain>
POSLA_FROM_EMAIL=noreply@<production-domain>
POSLA_SUPPORT_EMAIL=info@<production-domain>
POSLA_ALLOWED_ORIGINS=https://<production-domain>
POSLA_ALLOWED_HOSTS=<production-domain>

# Cell / deploy metadata.
POSLA_CELL_ID=cell-example
POSLA_ENVIRONMENT=production
POSLA_DEPLOY_VERSION=__REPLACE_IMAGE_OR_GIT_SHA__

# Set 1 for the single scheduler instance in this cell.
# Set 0 for additional app replicas.
POSLA_CRON_ENABLED=1

# Logs / cron.
POSLA_PHP_ERROR_LOG=/var/log/posla/php_errors.log
POSLA_CRON_SECRET=__REPLACE_CRON_SECRET__
POSLA_OPS_READ_SECRET=__REPLACE_SHARED_OPS_READ_SECRET__
