# Local host ports for this cell.
# Keep these unique per cell when multiple cells run on the same machine.
POSLA_CELL_HTTP_PORT=18081
POSLA_CELL_DB_PORT=13306

# PHP image artifact used by this cell.
# CI can replace this with a registry tag such as registry.example/posla/app:20260425-001.
POSLA_PHP_IMAGE=posla_php_cell:dev
